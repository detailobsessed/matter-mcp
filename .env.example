# Matter API token — generate at https://web.getmatter.com/settings (API Access section)
#
# Option A — 1Password (recommended):
#   1. Store your token in 1Password, note the vault/item/field path
#   2. Update the op:// reference below to match your vault structure
#   3. Run integration tests: op run --env-file=.env -- uv run pytest -m integration
#
# Option B — raw value (never commit):
#   MATTER_API_TOKEN=mat_your_token_here
#
MATTER_API_TOKEN=op://Personal/Matter API/token
